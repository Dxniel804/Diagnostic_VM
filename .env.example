# Copie este arquivo para .env e preencha os valores
# cp .env.example .env

# Obrigatório: chave da API do Google Gemini
# Acesse: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=sua_chave_aqui

# Opcional: modelo Gemini a usar (padrão: gemini-2.5-flash)
VITE_GEMINI_MODEL=gemini-2.5-flash

# Opcional: configurações de performance
MAX_RETRIES=6
RETRY_DELAY=2
REQUEST_DELAY=1.0
MAX_WORKERS=2

# Opcional: chave secreta do Flask (mude em produção)
SECRET_KEY=diagnostic_vm_secret_key_2024_persistent
